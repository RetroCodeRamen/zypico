{
  "name": "zypico",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "ZyPico — a retro LoRa-mesh social handheld (PWA). Product built on 'the Relay' network. See The-Relay-Outline-v2.md.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:logo": "python3 tools/gen-logo.py"
  },
  "dependencies": {
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wasmoon": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
